{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "tmdb-angular-sample": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/tmdb-angular-sample"
            },
            "index": "src/index.html",
            "polyfills": [
              "src/polyfills.ts"
            ],
            "tsConfig": "tsconfig.json",
            "assets": ["src/assets"],
            "styles": [
              "src/styles.css"
            ],
            "browser": "src/main.ts"
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "tmdb-angular-sample:build"
          }
        }
      }
    }
  },
  "defaultProject": "tmdb-angular-sample",
  "cli": {
    "analytics": "5f06d024-8eb3-4ecc-9794-a4b5d5ac2ca7"
  }
}